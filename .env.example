# Proprietor — environment template. Copy to `.env` and fill. `.env` is gitignored — never commit secrets.

# ── Secrets (you provide; do NOT paste these into chat) ───────────────────────
ANTHROPIC_API_KEY=            # CFO agent (Claude Agent SDK)
TAVILY_API_KEY=               # engine search
NEBIUS_API_KEY=               # engine inference (Nebius AI Studio)
NEBIUS_BASE_URL=              # OpenAI-compatible base URL from Nebius AI Studio, e.g. https://api.studio.nebius.com/v1
NEBIUS_MODEL=                 # e.g. an instruct model on TokenFactory
NEBIUS_FAST_MODEL=            # optional cheaper model for gap-id / extraction

# ── Circle / network (testnet — no real money) ───────────────────────────────
CIRCLE_CHAIN=ARC-TESTNET                 # confirm via `circle blockchain list` after accepting Terms
NETWORK_CAIP2=eip155:5042002             # Arc Testnet
FACILITATOR_URL=https://gateway-api-testnet.circle.com
ARC_RPC_URL=https://rpc.testnet.arc.network   # used by treasury.isDeployed (eth_getCode)

# Wallet addresses — filled by scripts/circle-setup.sh after you log in
TREASURY_WALLET_ADDRESS=      # the Proprietor business treasury (receives revenue, pays supplier)
SUPPLIER_WALLET_ADDRESS=      # the supplier-agent (receives Proprietor's per-call payments)
BUYER_WALLET_ADDRESS=         # the demo customer-agent (pays the storefront)

# ── Service wiring ────────────────────────────────────────────────────────────
ENGINE_URL=http://localhost:8000         # Python fulfilment engine (Clippy is building it)
SUPPLIER_URL=http://localhost:4000       # supplier-agent (Phase 2b)
STOREFRONT_PORT=3000
ECHO_PORT=4000

# ── Pricing (USD strings; placeholders — CFO tunes later) ─────────────────────
# RETAIL — what the buyer pays the storefront per depth.
PRICE_BASIC=$0.01
PRICE_STANDARD=$0.03
PRICE_COMPREHENSIVE=$0.08
# WHOLESALE — what the storefront pays the supplier per depth (must be < retail for margin).
WHOLESALE_BASIC=$0.005
WHOLESALE_STANDARD=$0.015
WHOLESALE_COMPREHENSIVE=$0.04

# ── Cost calibration (engine COGS estimate) ──────────────────────────────────
TAVILY_UNIT_USD=0.005
NEBIUS_USD_PER_TOKEN=0.0000004
CACHE_TTL_HOURS=24
