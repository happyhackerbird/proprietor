# Secrets — wallet keys, API keys (Circle / Tavily / Nebius) must never be committed
.env
.env.*
*.pem
*.key
wallet.json
secrets/

# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc

# Build / runtime
dist/
build/
.cache/
*.log

# Internal-only notes — references a private source project; never publish
internal/

# Local ledger / cache / state (regenerated at runtime)
data/*.db
data/*.db-*
data/*.sqlite*
data/*.local.json

# OS / editor
.DS_Store
.idea/
.vscode/
