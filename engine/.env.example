# Proprietor fulfilment engine — environment template.
# Copy to .env and fill in your provider keys. The engine boots and serves
# /healthz (and the offline test suite runs) with no keys set; keys are only
# required to make real /enrich and /preview requests.

# Tavily web-search API key.
TAVILY_API_KEY=

# Nebius LLM credentials and model selection.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Optional cheaper model for gap-id / extraction / disambiguation.
NEBIUS_FAST_MODEL=

# Cache time-to-live in hours, and the SQLite cache location.
CACHE_TTL_HOURS=24
DB_PATH=data/cache.db

# Cost-estimate unit prices (counts matter more than the dollar estimate).
TAVILY_UNIT_USD=0.008
NEBIUS_USD_PER_TOKEN=0.0000002

# Set to 1 (with real keys above) to run the live integration test.
# RUN_LIVE_TESTS=1
